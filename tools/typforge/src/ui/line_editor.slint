import { Button, CheckBox, ComboBox, LineEdit, ScrollView, SpinBox, TextEdit, Palette } from "std-widgets.slint";

export component LineEditor inherits Rectangle {
    background: #00000066;

    in-out property <string> title-text: "Ligne";

    // Identité
    in-out property <string> type-code-text: "0x00";
    in-out property <string> sub-type-text:  "0x00";

    // Style couleur
    in-out property <color>  day-color:   #000000;
    in-out property <string> day-text:    "#000000";
    in-out property <color>  night-color: #000000;
    in-out property <string> night-text:  "#000000";

    // Géométrie
    in-out property <int> line-width: 1;
    in-out property <int> bdr-width:  0;

    // Options
    in-out property <bool> use-orientation: true;
    in-out property <bool> extended-labels: false;
    in-out property <int>  font-style: 0;

    // XPM brut (section avancée)
    in-out property <string> xpm-text:       "";
    in-out property <string> night-xpm-text: "";

    // État
    in-out property <string> error-msg: "";

    // Callbacks
    callback day-text-changed(string);
    callback night-text-changed(string);
    callback pick-day-color();
    callback pick-night-color();
    callback dash-preset(int);
    callback apply();
    callback cancel();

    // ── Dialog centré ──────────────────────────────────────────────
    Rectangle {
        x: (parent.width  - self.width)  / 2;
        y: (parent.height - self.height) / 2;
        width:  min(parent.width  - 32px, 740px);
        height: min(parent.height - 32px, 580px);
        background: Palette.background;
        border-width: 1px;
        border-color: #444444;
        border-radius: 6px;
        clip: true;

        VerticalLayout {
            padding: 0px;

            // ── Header ──────────────────────────────────────────
            Rectangle {
                height: 42px;
                background: #1e5aa8;
                HorizontalLayout {
                    padding-left: 18px; padding-right: 8px;
                    Text {
                        text: root.title-text;
                        color: #ffffff; font-size: 14px; font-weight: 700;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    Rectangle {
                        width: 34px; height: 34px;
                        background: close-ta.has-hover ? #cc3333 : transparent;
                        border-radius: 4px;
                        Text {
                            text: "✕"; color: #ffffff; font-size: 14px;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                        close-ta := TouchArea { clicked => { root.cancel(); } }
                    }
                }
            }

            // ── Corps 2 colonnes ────────────────────────────────
            HorizontalLayout {
                vertical-stretch: 1;

                // ═══ FORMULAIRE GAUCHE ════════════════════════
                ScrollView {
                    width: 400px;

                    VerticalLayout {
                        padding: 20px; spacing: 0px; alignment: start;
                        width: 380px;

                        // ─ Section Identité ──────────────────
                        Text {
                            text: "IDENTITÉ";
                            font-size: 10px; font-weight: 700;
                            color: #5a80c0; letter-spacing: 1px;
                        }
                        Rectangle { height: 1px; background: #5a80c040; }
                        Rectangle { height: 10px; }

                        HorizontalLayout { spacing: 10px; alignment: start;
                            Text {
                                text: "Type :"; font-size: 12px; width: 100px;
                                vertical-alignment: center;
                            }
                            LineEdit { text <=> root.type-code-text; width: 100px; font-size: 12px; }
                        }
                        Rectangle { height: 8px; }
                        HorizontalLayout { spacing: 10px; alignment: start;
                            Text {
                                text: "Sous-type :"; font-size: 12px; width: 100px;
                                vertical-alignment: center;
                            }
                            LineEdit { text <=> root.sub-type-text; width: 100px; font-size: 12px; }
                        }
                        Rectangle { height: 20px; }

                        // ─ Section Style ─────────────────────
                        Text {
                            text: "STYLE";
                            font-size: 10px; font-weight: 700;
                            color: #5a80c0; letter-spacing: 1px;
                        }
                        Rectangle { height: 1px; background: #5a80c040; }
                        Rectangle { height: 10px; }

                        // Couleur Jour
                        HorizontalLayout { spacing: 10px; alignment: start;
                            Text {
                                text: "Couleur Jour :"; font-size: 12px; width: 120px;
                                vertical-alignment: center;
                            }
                            LineEdit {
                                text <=> root.day-text; width: 90px; font-size: 12px;
                                edited(v) => {
                                    root.xpm-text = "";
                                    root.error-msg = "";
                                    root.day-text-changed(v);
                                }
                            }
                            Rectangle {
                                width: 34px; height: 30px;
                                background: root.day-color;
                                border-width: 1px; border-color: #888888;
                                border-radius: 4px;
                                TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.pick-day-color(); }
                                }
                            }
                        }
                        Rectangle { height: 8px; }

                        // Couleur Nuit
                        HorizontalLayout { spacing: 10px; alignment: start;
                            Text {
                                text: "Couleur Nuit :"; font-size: 12px; width: 120px;
                                vertical-alignment: center;
                            }
                            LineEdit {
                                text <=> root.night-text; width: 90px; font-size: 12px;
                                edited(v) => {
                                    root.night-xpm-text = "";
                                    root.error-msg = "";
                                    root.night-text-changed(v);
                                }
                            }
                            Rectangle {
                                width: 34px; height: 30px;
                                background: root.night-color;
                                border-width: 1px; border-color: #888888;
                                border-radius: 4px;
                                TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.pick-night-color(); }
                                }
                            }
                        }
                        Rectangle { height: 8px; }

                        // Épaisseur ligne
                        HorizontalLayout { spacing: 10px; alignment: start;
                            Text {
                                text: "Épaisseur :"; font-size: 12px; width: 120px;
                                vertical-alignment: center;
                            }
                            SpinBox {
                                value <=> root.line-width;
                                minimum: 0; maximum: 20; width: 110px;
                            }
                            Text {
                                text: "px"; font-size: 12px; width: 24px;
                                vertical-alignment: center; color: #888888;
                            }
                        }
                        Rectangle { height: 8px; }

                        // Épaisseur bordure
                        HorizontalLayout { spacing: 10px; alignment: start;
                            Text {
                                text: "Bordure :"; font-size: 12px; width: 120px;
                                vertical-alignment: center;
                            }
                            SpinBox {
                                value <=> root.bdr-width;
                                minimum: 0; maximum: 20; width: 110px;
                            }
                            Text {
                                text: "px"; font-size: 12px; width: 24px;
                                vertical-alignment: center; color: #888888;
                            }
                        }
                        Rectangle { height: 8px; }

                        // UseOrientation
                        HorizontalLayout { spacing: 10px; alignment: start;
                            Text {
                                text: "Orientation :"; font-size: 12px; width: 120px;
                                vertical-alignment: center;
                            }
                            CheckBox { checked <=> root.use-orientation; }
                        }
                        Rectangle { height: 8px; }

                        // FontStyle
                        HorizontalLayout { spacing: 10px; alignment: start;
                            Text {
                                text: "Style police :"; font-size: 12px; width: 120px;
                                vertical-alignment: center;
                            }
                            ComboBox {
                                model: ["Défaut", "Sans label", "Petit", "Normal", "Grand"];
                                current-index <=> root.font-style;
                                width: 160px;
                            }
                        }
                        Rectangle { height: 8px; }

                        // ExtendedLabels
                        HorizontalLayout { spacing: 10px; alignment: start;
                            Text {
                                text: "Labels étendus :"; font-size: 12px; width: 120px;
                                vertical-alignment: center;
                            }
                            CheckBox { checked <=> root.extended-labels; }
                        }
                        Rectangle { height: 20px; }

                        // ─ Section Pointillés rapides ────────
                        Text {
                            text: "POINTILLÉS RAPIDES";
                            font-size: 10px; font-weight: 700;
                            color: #5a80c0; letter-spacing: 1px;
                        }
                        Rectangle { height: 1px; background: #5a80c040; }
                        Rectangle { height: 8px; }
                        Text {
                            text: "Génère un motif XPM (jour). Ajuste la couleur\net l'épaisseur avant d'appliquer.";
                            font-size: 10px; color: #888888; wrap: word-wrap;
                        }
                        Rectangle { height: 6px; }
                        HorizontalLayout { spacing: 6px; alignment: start;
                            Button {
                                text: "— — —"; height: 28px; width: 70px;
                                clicked => { root.dash-preset(0); }
                            }
                            Button {
                                text: "– – –"; height: 28px; width: 70px;
                                clicked => { root.dash-preset(1); }
                            }
                            Button {
                                text: "· · ·"; height: 28px; width: 70px;
                                clicked => { root.dash-preset(2); }
                            }
                            Button {
                                text: "—·—"; height: 28px; width: 70px;
                                clicked => { root.dash-preset(3); }
                            }
                        }
                        Rectangle { height: 4px; }
                        HorizontalLayout { spacing: 6px; alignment: start;
                            Text { text: "Longs"; font-size: 9px; color: #888888; width: 70px; horizontal-alignment: center; }
                            Text { text: "Courts"; font-size: 9px; color: #888888; width: 70px; horizontal-alignment: center; }
                            Text { text: "Points"; font-size: 9px; color: #888888; width: 70px; horizontal-alignment: center; }
                            Text { text: "Tiret·pt"; font-size: 9px; color: #888888; width: 70px; horizontal-alignment: center; }
                        }
                        Rectangle { height: 16px; }

                        // ─ Section XPM avancé ────────────────
                        Text {
                            text: "MOTIF XPM (AVANCÉ)";
                            font-size: 10px; font-weight: 700;
                            color: #5a80c0; letter-spacing: 1px;
                        }
                        Rectangle { height: 1px; background: #5a80c040; }
                        Rectangle { height: 10px; }

                        Text { text: "Motif Jour (XPM brut) :"; font-size: 11px; }
                        Rectangle { height: 4px; }
                        TextEdit { height: 80px; text <=> root.xpm-text; font-size: 10px; }
                        Rectangle { height: 10px; }
                        Text { text: "Motif Nuit (XPM brut) :"; font-size: 11px; }
                        Rectangle { height: 4px; }
                        TextEdit { height: 60px; text <=> root.night-xpm-text; font-size: 10px; }
                    }
                }

                // Séparateur vertical
                Rectangle { width: 1px; background: Palette.border; }

                // ═══ PANNEAU APERÇU DROIT ═════════════════════
                VerticalLayout {
                    horizontal-stretch: 1;
                    padding: 20px; spacing: 0px; alignment: start;

                    Text {
                        text: "APERÇU EN DIRECT";
                        font-size: 10px; font-weight: 700;
                        color: #5a80c0; letter-spacing: 1px;
                    }
                    Rectangle { height: 1px; background: #5a80c040; }
                    Rectangle { height: 16px; }

                    // Aperçu Jour
                    Text {
                        text: "Jour"; font-size: 12px; font-weight: 700;
                    }
                    Rectangle { height: 8px; }
                    Rectangle {
                        height: 110px;
                        background: #e8e8e0;
                        border-radius: 6px;
                        border-width: 1px; border-color: Palette.border;
                        clip: true;

                        // Bordure (derrière la ligne principale, si bdr-width > 0)
                        if root.bdr-width > 0 && root.line-width > 0 : Rectangle {
                            y: (parent.height - (root.line-width + root.bdr-width * 2) * 1px) / 2;
                            x: 10px;
                            width: parent.width - 20px;
                            height: (root.line-width + root.bdr-width * 2) * 1px;
                            background: #555555;
                        }
                        // Ligne principale (live via line-width + day-color)
                        if root.line-width > 0 : Rectangle {
                            y: (parent.height - root.line-width * 1px) / 2;
                            x: 10px;
                            width: parent.width - 20px;
                            height: root.line-width * 1px;
                            background: root.day-color;
                        }
                        // Badge épaisseur
                        Rectangle {
                            x: parent.width - 38px; y: parent.height - 22px;
                            width: 32px; height: 16px;
                            background: #00000033; border-radius: 3px;
                            Text {
                                text: root.line-width + "px";
                                font-size: 9px; color: #444444;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                    }
                    Rectangle { height: 16px; }

                    // Aperçu Nuit
                    Text {
                        text: "Nuit"; font-size: 12px; font-weight: 700;
                    }
                    Rectangle { height: 8px; }
                    Rectangle {
                        height: 110px;
                        background: #1e2530;
                        border-radius: 6px;
                        border-width: 1px; border-color: #555555;
                        clip: true;

                        if root.bdr-width > 0 && root.line-width > 0 : Rectangle {
                            y: (parent.height - (root.line-width + root.bdr-width * 2) * 1px) / 2;
                            x: 10px;
                            width: parent.width - 20px;
                            height: (root.line-width + root.bdr-width * 2) * 1px;
                            background: #aaaaaa;
                            opacity: 0.6;
                        }
                        if root.line-width > 0 : Rectangle {
                            y: (parent.height - root.line-width * 1px) / 2;
                            x: 10px;
                            width: parent.width - 20px;
                            height: root.line-width * 1px;
                            background: root.night-color;
                        }
                        Rectangle {
                            x: parent.width - 38px; y: parent.height - 22px;
                            width: 32px; height: 16px;
                            background: #ffffff15; border-radius: 3px;
                            Text {
                                text: root.line-width + "px";
                                font-size: 9px; color: #aaaaaa;
                                horizontal-alignment: center; vertical-alignment: center;
                            }
                        }
                    }
                    Rectangle { height: 16px; }

                    // Aide
                    Text {
                        text: "L'épaisseur et la couleur\nse mettent à jour en direct.";
                        font-size: 10px; color: #888888; wrap: word-wrap;
                    }
                }
            }

            // ── Barre erreur ────────────────────────────────────
            if root.error-msg != "" : Rectangle {
                height: 32px;
                background: #ffdddd;
                border-width: 1px; border-color: #cc4444;
                Text {
                    text: root.error-msg;
                    color: #cc0000; font-size: 11px;
                    horizontal-alignment: center; vertical-alignment: center;
                    overflow: elide;
                }
            }

            // ── Footer ──────────────────────────────────────────
            Rectangle {
                height: 52px;
                background: Palette.control-background;
                border-width: 1px; border-color: Palette.border;
                HorizontalLayout {
                    padding: 10px; spacing: 10px; alignment: end;
                    Button {
                        text: "Annuler"; height: 34px;
                        clicked => { root.cancel(); }
                    }
                    Button {
                        text: "Appliquer"; height: 34px;
                        clicked => { root.apply(); }
                    }
                }
            }
        }
    }
}
