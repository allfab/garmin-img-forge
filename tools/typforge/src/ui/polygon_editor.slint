import { Button, CheckBox, ComboBox, LineEdit, ScrollView, TextEdit, Palette } from "std-widgets.slint";
import { XpmPreview } from "xpm_preview.slint";
import { DrawMaskEditor } from "draw_mask_editor.slint";

export component PolygonEditor inherits Rectangle {
    background: #00000066;

    in-out property <string> title-text: "Polygone";

    // Identité
    in-out property <string> type-code-text: "0x00";
    in-out property <string> sub-type-text:  "0x00";
    in-out property <string> grmn-type-text: "";

    // Mode Solide / Motif
    in-out property <bool> is-pattern: false;

    // Style couleur (mode Solide)
    in-out property <color>  day-fill-color:   #888888;
    in-out property <string> day-fill-text:    "#888888";
    in-out property <color>  night-fill-color: #888888;
    in-out property <string> night-fill-text:  "#888888";

    // Contour
    in-out property <bool>   contour-enabled: false;
    in-out property <color>  contour-color:   #000000;
    in-out property <string> contour-text:    "#000000";

    // Typographie
    in-out property <bool>   extended-labels: false;
    in-out property <int>    font-style: 0;

    // XPM brut (section avancée)
    in-out property <string> xpm-text:       "";
    in-out property <string> night-xpm-text: "";

    // Previews XPM précalculées par Rust
    in property <image> day-xpm-preview-image;
    in property <image> night-xpm-preview-image;

    // ── Propriétés DrawMaskEditor (mode Motif) ────────
    in property <image>    dm-grid-image;
    in-out property <int>  dm-zoom: 8;
    in-out property <int>  dm-num-rows: 32;
    in-out property <int>  dm-tool: 0;
    in-out property <color>  dm-fg-color: #000000;
    in-out property <color>  dm-bg-color: #ffffff;
    in-out property <bool>   dm-bg-is-clear: true;
    in-out property <bool>   dm-has-night: false;
    in-out property <bool>   dm-editing-night: false;
    in-out property <color>  dm-night-fg-color: #ffffff;
    in-out property <color>  dm-night-bg-color: #000000;
    in-out property <bool>   dm-night-bg-is-clear: true;
    in-out property <bool>   dm-night-same-as-day: true;

    // État
    in-out property <string> error-msg: "";

    // Callbacks Solide
    callback day-text-changed(string);
    callback night-text-changed(string);
    callback contour-text-changed(string);
    callback xpm-text-edited(string);
    callback night-xpm-text-edited(string);
    callback pick-day-color();
    callback pick-night-color();
    callback pick-contour-color();

    // Callbacks DrawMask
    callback dm-grid-clicked(float, float, int);
    callback dm-pick-fg-color();
    callback dm-pick-bg-color();
    callback dm-pick-night-fg-color();
    callback dm-pick-night-bg-color();
    callback dm-zoom-changed(int);
    callback dm-tool-changed(int);
    callback dm-toggle-night();

    callback apply();
    callback cancel();

    // Capture tous les clics sur le fond semi-transparent
    TouchArea {}

    // ── Dialog centré ──────────────────────────────────────────────
    Rectangle {
        x: (parent.width  - self.width)  / 2;
        y: (parent.height - self.height) / 2;
        width:  min(parent.width  - 32px, 860px);
        height: min(parent.height - 32px, 700px);
        background: Palette.background;
        border-width: 1px;
        border-color: #444444;
        border-radius: 6px;
        clip: true;

        VerticalLayout {
            padding: 0px;

            // ── Header ──────────────────────────────────────────
            Rectangle {
                height: 42px;
                background: #1e5aa8;
                HorizontalLayout {
                    padding-left: 18px; padding-right: 8px;
                    Text {
                        text: root.title-text;
                        color: #ffffff; font-size: 14px; font-weight: 700;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    Rectangle {
                        width: 34px; height: 34px;
                        background: close-ta.has-hover ? #cc3333 : transparent;
                        border-radius: 4px;
                        Text {
                            text: "×"; color: #ffffff; font-size: 18px;
                            horizontal-alignment: center; vertical-alignment: center;
                        }
                        close-ta := TouchArea { mouse-cursor: pointer; clicked => { root.cancel(); } }
                    }
                }
            }

            // ── Corps 2 colonnes ────────────────────────────────
            HorizontalLayout {
                vertical-stretch: 1;

                // ═══ FORMULAIRE GAUCHE ════════════════════════
                ScrollView {
                    width: 420px;

                    VerticalLayout {
                        padding: 20px; spacing: 0px; alignment: start;
                        width: 400px;

                        // ─ Section Identité ──────────────────
                        Text {
                            text: "IDENTITÉ";
                            font-size: 10px; font-weight: 700;
                            color: #5a80c0; letter-spacing: 1px;
                        }
                        Rectangle { height: 1px; background: #5a80c040; }
                        Rectangle { height: 10px; }

                        HorizontalLayout { spacing: 10px; alignment: start;
                            Text { text: "Type :"; font-size: 12px; width: 100px; vertical-alignment: center; color: Palette.foreground; }
                            LineEdit { text <=> root.type-code-text; width: 100px; font-size: 12px; }
                        }
                        Rectangle { height: 8px; }
                        HorizontalLayout { spacing: 10px; alignment: start;
                            Text { text: "Sous-type :"; font-size: 12px; width: 100px; vertical-alignment: center; color: Palette.foreground; }
                            LineEdit { text <=> root.sub-type-text; width: 100px; font-size: 12px; }
                        }
                        Rectangle { height: 8px; }
                        HorizontalLayout { spacing: 10px; alignment: start;
                            Text { text: "Désignation :"; font-size: 12px; width: 100px; vertical-alignment: center; color: Palette.foreground; }
                            LineEdit {
                                text <=> root.grmn-type-text;
                                horizontal-stretch: 1; font-size: 12px;
                                placeholder-text: "ex: Roads/OTHER_HWY/Description/Non NT";
                            }
                        }
                        Rectangle { height: 20px; }

                        // ─ Section Style ─────────────────────
                        Text {
                            text: "STYLE";
                            font-size: 10px; font-weight: 700;
                            color: #5a80c0; letter-spacing: 1px;
                        }
                        Rectangle { height: 1px; background: #5a80c040; }
                        Rectangle { height: 10px; }

                        // Radio Solide / Motif
                        HorizontalLayout { spacing: 12px; alignment: start;
                            Text { text: "Mode :"; font-size: 12px; width: 60px; vertical-alignment: center; }
                            Rectangle {
                                width: 84px; height: 22px;
                                HorizontalLayout {
                                    alignment: start; spacing: 6px;
                                    VerticalLayout { alignment: center; width: 14px;
                                        Rectangle {
                                            width: 14px; height: 14px; border-radius: 7px; border-width: 2px;
                                            border-color: !root.is-pattern ? #3080ff : #888;
                                            background: !root.is-pattern ? #3080ff : transparent;
                                        }
                                    }
                                    Text { text: "Solide"; font-size: 12px; vertical-alignment: center; }
                                }
                                TouchArea { mouse-cursor: pointer; clicked => { root.is-pattern = false; } }
                            }
                            Rectangle {
                                width: 72px; height: 22px;
                                HorizontalLayout {
                                    alignment: start; spacing: 6px;
                                    VerticalLayout { alignment: center; width: 14px;
                                        Rectangle {
                                            width: 14px; height: 14px; border-radius: 7px; border-width: 2px;
                                            border-color: root.is-pattern ? #3080ff : #888;
                                            background: root.is-pattern ? #3080ff : transparent;
                                        }
                                    }
                                    Text { text: "Motif"; font-size: 12px; vertical-alignment: center; }
                                }
                                TouchArea { mouse-cursor: pointer; clicked => { root.is-pattern = true; } }
                            }
                        }
                        Rectangle { height: 12px; }

                        // ── Mode Solide ──────────────────────
                        if !root.is-pattern : VerticalLayout {
                            spacing: 0px;

                            HorizontalLayout { spacing: 10px; alignment: start;
                                Text { text: "Couleur Jour :"; font-size: 12px; width: 120px; vertical-alignment: center; }
                                LineEdit {
                                    text <=> root.day-fill-text; width: 90px; font-size: 12px;
                                    edited(v) => { root.xpm-text = ""; root.error-msg = ""; root.day-text-changed(v); }
                                }
                                Rectangle {
                                    width: 34px; height: 30px; background: root.day-fill-color;
                                    border-width: 1px; border-color: #888888; border-radius: 4px;
                                    TouchArea { mouse-cursor: pointer; clicked => { root.pick-day-color(); } }
                                }
                            }
                            Rectangle { height: 8px; }

                            HorizontalLayout { spacing: 10px; alignment: start;
                                Text { text: "Couleur Nuit :"; font-size: 12px; width: 120px; vertical-alignment: center; }
                                LineEdit {
                                    text <=> root.night-fill-text; width: 90px; font-size: 12px;
                                    edited(v) => { root.night-xpm-text = ""; root.error-msg = ""; root.night-text-changed(v); }
                                }
                                Rectangle {
                                    width: 34px; height: 30px; background: root.night-fill-color;
                                    border-width: 1px; border-color: #888888; border-radius: 4px;
                                    TouchArea { mouse-cursor: pointer; clicked => { root.pick-night-color(); } }
                                }
                            }
                            Rectangle { height: 8px; }

                            HorizontalLayout { spacing: 10px; alignment: start;
                                Text { text: "Contour :"; font-size: 12px; width: 120px; vertical-alignment: center; }
                                CheckBox {
                                    checked <=> root.contour-enabled;
                                    text: root.contour-enabled ? "Couleur" : "Aucun";
                                }
                                if root.contour-enabled : LineEdit {
                                    text <=> root.contour-text; width: 80px; font-size: 12px;
                                    edited(v) => { root.contour-text-changed(v); }
                                }
                                if root.contour-enabled : Rectangle {
                                    width: 34px; height: 30px; background: root.contour-color;
                                    border-width: 1px; border-color: #888888; border-radius: 4px;
                                    TouchArea { mouse-cursor: pointer; clicked => { root.pick-contour-color(); } }
                                }
                            }
                            Rectangle { height: 8px; }
                        }

                        // ── Mode Motif ───────────────────────
                        if root.is-pattern : DrawMaskEditor {
                            grid-image: root.dm-grid-image;
                            zoom <=> root.dm-zoom;
                            num-rows: root.dm-num-rows;
                            max-rows: 32;
                            fixed-rows: true;
                            fg-color <=> root.dm-fg-color;
                            bg-color <=> root.dm-bg-color;
                            bg-is-clear <=> root.dm-bg-is-clear;
                            has-night <=> root.dm-has-night;
                            editing-night <=> root.dm-editing-night;
                            night-fg-color <=> root.dm-night-fg-color;
                            night-bg-color <=> root.dm-night-bg-color;
                            night-bg-is-clear <=> root.dm-night-bg-is-clear;
                            night-same-as-day <=> root.dm-night-same-as-day;
                            show-wide-tool: false;
                            active-tool <=> root.dm-tool;
                            grid-clicked(x, y, b)    => { root.dm-grid-clicked(x, y, b); }
                            pick-fg-color            => { root.dm-pick-fg-color(); }
                            pick-bg-color            => { root.dm-pick-bg-color(); }
                            pick-night-fg-color      => { root.dm-pick-night-fg-color(); }
                            pick-night-bg-color      => { root.dm-pick-night-bg-color(); }
                            zoom-changed(v)          => { root.dm-zoom-changed(v); }
                            tool-changed(v)          => { root.dm-tool-changed(v); }
                            toggle-night             => { root.dm-toggle-night(); }
                        }

                        Rectangle { height: 16px; }

                        // ─ Options communes ──────────────────
                        Text {
                            text: "OPTIONS";
                            font-size: 10px; font-weight: 700;
                            color: #5a80c0; letter-spacing: 1px;
                        }
                        Rectangle { height: 1px; background: #5a80c040; }
                        Rectangle { height: 10px; }

                        HorizontalLayout { spacing: 10px; alignment: start;
                            Text { text: "Style police :"; font-size: 12px; width: 120px; vertical-alignment: center; }
                            ComboBox {
                                model: ["Défaut", "Sans label", "Petit", "Normal", "Grand"];
                                current-index <=> root.font-style;
                                width: 160px;
                            }
                        }
                        Rectangle { height: 8px; }

                        HorizontalLayout { spacing: 10px; alignment: start;
                            Text { text: "Labels étendus :"; font-size: 12px; width: 120px; vertical-alignment: center; }
                            CheckBox { checked <=> root.extended-labels; }
                        }
                        Rectangle { height: 20px; }

                        // ─ Section XPM avancé ────────────────
                        Text {
                            text: "MOTIF XPM (AVANCÉ)";
                            font-size: 10px; font-weight: 700;
                            color: #5a80c0; letter-spacing: 1px;
                        }
                        Rectangle { height: 1px; background: #5a80c040; }
                        Rectangle { height: 10px; }

                        HorizontalLayout { spacing: 8px;
                            VerticalLayout { spacing: 4px; horizontal-stretch: 1;
                                Text { text: "XPM Jour :"; font-size: 11px; color: Palette.foreground; }
                                TextEdit {
                                    height: 80px; text: root.xpm-text; font-size: 10px;
                                    edited(v) => { root.xpm-text = v; root.xpm-text-edited(v); }
                                }
                            }
                            VerticalLayout { spacing: 4px; horizontal-stretch: 1;
                                Text { text: "XPM Nuit :"; font-size: 11px; color: Palette.foreground; }
                                TextEdit {
                                    height: 80px; text: root.night-xpm-text; font-size: 10px;
                                    edited(v) => { root.night-xpm-text = v; root.night-xpm-text-edited(v); }
                                }
                            }
                        }
                    }
                }

                // Séparateur vertical
                Rectangle { width: 1px; background: Palette.border; }

                // ═══ PANNEAU APERÇU DROIT ═════════════════════
                VerticalLayout {
                    horizontal-stretch: 1;
                    padding: 20px; spacing: 0px; alignment: start;

                    Text {
                        text: "APERÇU EN DIRECT";
                        font-size: 10px; font-weight: 700;
                        color: #5a80c0; letter-spacing: 1px;
                    }
                    Rectangle { height: 1px; background: #5a80c040; }
                    Rectangle { height: 16px; }

                    Text { text: "Jour"; font-size: 12px; font-weight: 700; color: Palette.foreground; }
                    Rectangle { height: 8px; }
                    XpmPreview {
                        height: 130px;
                        preview-image: root.day-xpm-preview-image;
                        is-night: false;
                    }
                    Rectangle { height: 16px; }

                    Text { text: "Nuit"; font-size: 12px; font-weight: 700; color: Palette.foreground; }
                    Rectangle { height: 8px; }
                    XpmPreview {
                        height: 130px;
                        preview-image: root.night-xpm-preview-image;
                        is-night: true;
                    }
                    Rectangle { height: 16px; }

                    Text {
                        text: root.is-pattern
                            ? "Aperçu du motif binaire tuilé\n(avant-plan + arrière-plan)."
                            : "Cliquer sur le swatch pour\nouvrir le sélecteur de couleur.";
                        font-size: 10px; color: #888888; wrap: word-wrap;
                    }
                }
            }

            // ── Barre erreur ────────────────────────────────────
            if root.error-msg != "" : Rectangle {
                height: 32px;
                background: #ffdddd;
                border-width: 1px; border-color: #cc4444;
                Text {
                    text: root.error-msg;
                    color: #cc0000; font-size: 11px;
                    horizontal-alignment: center; vertical-alignment: center;
                    overflow: elide;
                }
            }

            // ── Footer ──────────────────────────────────────────
            Rectangle {
                height: 52px;
                background: Palette.control-background;
                border-width: 1px; border-color: Palette.border;
                HorizontalLayout {
                    padding: 10px; spacing: 10px; alignment: end;
                    Button { text: "Annuler"; height: 34px; clicked => { root.cancel(); } }
                    Button { text: "Appliquer"; height: 34px; clicked => { root.apply(); } }
                }
            }
        }
    }
}
