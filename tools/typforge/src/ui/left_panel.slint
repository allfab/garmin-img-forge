import { ScrollView, Button, LineEdit, ComboBox, StandardListView, Palette } from "std-widgets.slint";

export component LeftPanel inherits Rectangle {
    width: 260px;
    background: Palette.alternate-background;

    in-out property <string> meta-family-id: "0";
    in-out property <string> meta-product-code: "1";
    in-out property <string> meta-header-str: "";
    in-out property <int>    meta-codepage: 1252;

    in property <[StandardListViewItem]> polygons-model: [];
    in property <[StandardListViewItem]> lines-model: [];
    in property <[StandardListViewItem]> points-model: [];
    in property <[StandardListViewItem]> extra-pois-model: [];
    in property <[StandardListViewItem]> draworder-model: [];

    in-out property <int> active-list-selection: -1;

    // Sélection courante par liste (pour boutons Éditer/Supprimer et double-clic)
    private property <int> poly-sel: -1;
    private property <int> line-sel: -1;
    private property <int> point-sel: -1;
    private property <int> icon-sel: -1;

    callback add-element(int);
    callback edit-element(int, int);
    callback delete-element(int, int);
    callback element-selected(int, int);
    callback edit-draworder();

    ScrollView {
        VerticalLayout {
            padding: 4px;
            spacing: 4px;
            alignment: start;

            // ── Métadonnées ──────────────────────────────
            Rectangle {
                height: 20px;
                background: Palette.control-background;
                border-radius: 2px;
                Text { text: "Métadonnées [_id]"; font-size: 11px; font-weight: 700; x: 4px; vertical-alignment: center; color: Palette.foreground; }
            }
            HorizontalLayout { spacing: 4px;
                Text { text: "FID:"; font-size: 11px; width: 70px; vertical-alignment: center; }
                LineEdit { text <=> root.meta-family-id; }
            }
            HorizontalLayout { spacing: 4px;
                Text { text: "Product:"; font-size: 11px; width: 70px; vertical-alignment: center; }
                LineEdit { text <=> root.meta-product-code; }
            }
            HorizontalLayout { spacing: 4px;
                Text { text: "CodePage:"; font-size: 11px; width: 70px; vertical-alignment: center; }
                ComboBox {
                    model: ["1252 (CP1252)", "65001 (UTF-8)"];
                    current-index: root.meta-codepage == 65001 ? 1 : 0;
                    selected(v) => { root.meta-codepage = v == "65001 (UTF-8)" ? 65001 : 1252; }
                }
            }
            HorizontalLayout { spacing: 4px;
                Text { text: "En-tête:"; font-size: 11px; width: 70px; vertical-alignment: center; }
                LineEdit { text <=> root.meta-header-str; }
            }

            Rectangle { height: 6px; }
            Rectangle { height: 1px; background: Palette.border; }
            Rectangle { height: 4px; }

            // ── Polygones ────────────────────────────────
            Rectangle {
                height: 22px;
                background: Palette.accent-background;
                border-radius: 3px;
                border-width: 1px;
                border-color: Palette.border;
                HorizontalLayout {
                    padding-left: 6px;
                    Text { text: "Polygones"; font-size: 11px; font-weight: 700; vertical-alignment: center; color: Palette.accent-foreground; }
                }
            }
            ScrollView {
                height: 100px;
                VerticalLayout {
                    alignment: start;
                    for item[idx] in root.polygons-model: Rectangle {
                        height: 22px;
                        background: poly-row-ta.has-hover ? Palette.alternate-background
                                  : (poly-sel == idx ? #d0e8ff : Palette.background);
                        border-width: 1px;
                        border-color: poly-sel == idx ? #3080ff : Palette.border;
                        poly-row-ta := TouchArea {
                            clicked => {
                                poly-sel = idx;
                                root.element-selected(0, idx);
                            }
                            double-clicked => {
                                poly-sel = idx;
                                root.element-selected(0, idx);
                                root.edit-element(0, idx);
                            }
                        }
                        Text {
                            x: 6px;
                            text: item.text;
                            vertical-alignment: center;
                            font-size: 11px;
                            overflow: elide;
                            color: poly-sel == idx ? #3080ff : Palette.foreground;
                        }
                    }
                }
            }
            HorizontalLayout { spacing: 2px;
                Button { text: "+"; height: 22px; clicked => { root.add-element(0); } }
                Button { text: "Éditer"; height: 22px; clicked => { root.edit-element(0, poly-sel); } }
                Button { text: "×"; height: 22px; clicked => { root.delete-element(0, poly-sel); } }
            }

            Rectangle { height: 6px; }
            Rectangle { height: 1px; background: Palette.border; }
            Rectangle { height: 4px; }

            // ── Polylignes ────────────────────────────────
            Rectangle {
                height: 22px;
                background: Palette.accent-background;
                border-radius: 3px;
                border-width: 1px;
                border-color: Palette.border;
                HorizontalLayout {
                    padding-left: 6px;
                    Text { text: "Polylignes"; font-size: 11px; font-weight: 700; vertical-alignment: center; color: Palette.accent-foreground; }
                }
            }
            ScrollView {
                height: 100px;
                VerticalLayout {
                    alignment: start;
                    for item[idx] in root.lines-model: Rectangle {
                        height: 22px;
                        background: line-row-ta.has-hover ? Palette.alternate-background
                                  : (line-sel == idx ? #d0e8ff : Palette.background);
                        border-width: 1px;
                        border-color: line-sel == idx ? #3080ff : Palette.border;
                        line-row-ta := TouchArea {
                            clicked => {
                                line-sel = idx;
                                root.element-selected(1, idx);
                            }
                            double-clicked => {
                                line-sel = idx;
                                root.element-selected(1, idx);
                                root.edit-element(1, idx);
                            }
                        }
                        Text {
                            x: 6px;
                            text: item.text;
                            vertical-alignment: center;
                            font-size: 11px;
                            overflow: elide;
                            color: line-sel == idx ? #3080ff : Palette.foreground;
                        }
                    }
                }
            }
            HorizontalLayout { spacing: 2px;
                Button { text: "+"; height: 22px; clicked => { root.add-element(1); } }
                Button { text: "Éditer"; height: 22px; clicked => { root.edit-element(1, line-sel); } }
                Button { text: "×"; height: 22px; clicked => { root.delete-element(1, line-sel); } }
            }

            Rectangle { height: 6px; }
            Rectangle { height: 1px; background: Palette.border; }
            Rectangle { height: 4px; }

            // ── POIs ─────────────────────────────────────
            Rectangle {
                height: 22px;
                background: Palette.accent-background;
                border-radius: 3px;
                border-width: 1px;
                border-color: Palette.border;
                HorizontalLayout {
                    padding-left: 6px;
                    Text { text: "POIs"; font-size: 11px; font-weight: 700; vertical-alignment: center; color: Palette.accent-foreground; }
                }
            }
            ScrollView {
                height: 100px;
                VerticalLayout {
                    alignment: start;
                    for item[idx] in root.points-model: Rectangle {
                        height: 22px;
                        background: point-row-ta.has-hover ? Palette.alternate-background
                                  : (point-sel == idx ? #d0e8ff : Palette.background);
                        border-width: 1px;
                        border-color: point-sel == idx ? #3080ff : Palette.border;
                        point-row-ta := TouchArea {
                            clicked => {
                                point-sel = idx;
                                root.element-selected(2, idx);
                            }
                            double-clicked => {
                                point-sel = idx;
                                root.element-selected(2, idx);
                                root.edit-element(2, idx);
                            }
                        }
                        Text {
                            x: 6px;
                            text: item.text;
                            vertical-alignment: center;
                            font-size: 11px;
                            overflow: elide;
                            color: point-sel == idx ? #3080ff : Palette.foreground;
                        }
                    }
                }
            }
            HorizontalLayout { spacing: 2px;
                Button { text: "+"; height: 22px; clicked => { root.add-element(2); } }
                Button { text: "Éditer"; height: 22px; clicked => { root.edit-element(2, point-sel); } }
                Button { text: "×"; height: 22px; clicked => { root.delete-element(2, point-sel); } }
            }

            Rectangle { height: 6px; }
            Rectangle { height: 1px; background: Palette.border; }
            Rectangle { height: 4px; }

            // ── Extra POIs ───────────────────────────────
            Rectangle {
                height: 22px;
                background: Palette.accent-background;
                border-radius: 3px;
                border-width: 1px;
                border-color: Palette.border;
                HorizontalLayout {
                    padding-left: 6px;
                    Text { text: "Extra POIs"; font-size: 11px; font-weight: 700; vertical-alignment: center; color: Palette.accent-foreground; }
                }
            }
            ScrollView {
                height: 80px;
                VerticalLayout {
                    alignment: start;
                    for item[idx] in root.extra-pois-model: Rectangle {
                        height: 22px;
                        background: icon-row-ta.has-hover ? Palette.alternate-background
                                  : (icon-sel == idx ? #d0e8ff : Palette.background);
                        border-width: 1px;
                        border-color: icon-sel == idx ? #3080ff : Palette.border;
                        icon-row-ta := TouchArea {
                            clicked => {
                                icon-sel = idx;
                                root.element-selected(3, idx);
                            }
                            double-clicked => {
                                icon-sel = idx;
                                root.element-selected(3, idx);
                                root.edit-element(3, idx);
                            }
                        }
                        Text {
                            x: 6px;
                            text: item.text;
                            vertical-alignment: center;
                            font-size: 11px;
                            overflow: elide;
                            color: icon-sel == idx ? #3080ff : Palette.foreground;
                        }
                    }
                }
            }
            HorizontalLayout { spacing: 2px;
                Button { text: "+"; height: 22px; clicked => { root.add-element(3); } }
                Button { text: "Éditer"; height: 22px; clicked => { root.edit-element(3, icon-sel); } }
                Button { text: "×"; height: 22px; clicked => { root.delete-element(3, icon-sel); } }
            }

            Rectangle { height: 6px; }
            Rectangle { height: 1px; background: Palette.border; }
            Rectangle { height: 4px; }

            // ── DrawOrder ────────────────────────────────
            Rectangle {
                height: 22px;
                background: Palette.control-background;
                border-radius: 3px;
                border-width: 1px;
                border-color: Palette.border;
                HorizontalLayout {
                    padding-left: 6px;
                    Text { text: "DrawOrder"; font-size: 11px; font-weight: 700; vertical-alignment: center; color: Palette.foreground; }
                }
            }
            StandardListView {
                height: 70px;
                model: root.draworder-model;
            }
            Button {
                text: "Modifier DrawOrder";
                height: 24px;
                clicked => { root.edit-draworder(); }
            }

            Rectangle { height: 8px; }
        }
    }
}
