import { ScrollView, Button, StandardListView, Palette } from "std-widgets.slint";

export component LeftPanel inherits Rectangle {
    background: Palette.alternate-background;

    in property <[StandardListViewItem]> polygons-model: [];
    in property <[StandardListViewItem]> lines-model: [];
    in property <[StandardListViewItem]> points-model: [];
    in property <[StandardListViewItem]> extra-pois-model: [];
    in property <[StandardListViewItem]> draworder-model: [];

    in property <int> poly-count: 0;
    in property <int> line-count: 0;
    in property <int> point-count: 0;
    in property <int> poi-count: 0;

    in-out property <int> active-list-selection: -1;

    private property <int> poly-sel: -1;
    private property <int> line-sel: -1;
    private property <int> point-sel: -1;
    private property <int> icon-sel: -1;

    callback add-element(int);
    callback edit-element(int, int);
    callback delete-element(int, int);
    callback element-selected(int, int);
    callback edit-draworder();

    VerticalLayout {
        padding: 4px;
        spacing: 3px;

        // ── Polygones ───────────────────────────────────
        Rectangle {
            height: 18px;
            background: Palette.control-background;
            border-radius: 2px;
            border-width: 1px;
            border-color: Palette.border;
            Text {
                text: "Liste des polygones (" + root.poly-count + ")";
                font-size: 11px; font-weight: 700; x: 4px; vertical-alignment: center;
            }
        }
        HorizontalLayout {
            spacing: 2px;
            min-height: 100px;
            vertical-stretch: 1;

            ScrollView {
                horizontal-stretch: 1;
                VerticalLayout {
                    alignment: start;
                    for item[idx] in root.polygons-model: Rectangle {
                        height: 20px;
                        background: poly-row-ta.has-hover ? Palette.alternate-background
                                  : (poly-sel == idx ? #c8deff : Palette.background);
                        border-width: 1px;
                        border-color: poly-sel == idx ? #3060cc : Palette.border;
                        poly-row-ta := TouchArea {
                            clicked => { poly-sel = idx; root.element-selected(0, idx); }
                            double-clicked => { poly-sel = idx; root.element-selected(0, idx); root.edit-element(0, idx); }
                        }
                        Text {
                            x: 6px; text: item.text; vertical-alignment: center;
                            font-size: 11px; overflow: elide;
                            color: poly-sel == idx ? #0040cc : Palette.foreground;
                        }
                    }
                }
            }
            VerticalLayout {
                width: 65px; spacing: 2px; alignment: start;
                Button { text: "Ajouter"; height: 24px; clicked => { root.add-element(0); } }
                Button { text: "Modifier"; height: 24px; enabled: poly-sel >= 0; clicked => { root.edit-element(0, poly-sel); } }
                Button { text: "Supprimer"; height: 24px; enabled: poly-sel >= 0; clicked => { root.delete-element(0, poly-sel); } }
            }
        }

        Rectangle { height: 1px; background: Palette.border; }

        // ── Polylignes ──────────────────────────────────
        Rectangle {
            height: 18px;
            background: Palette.control-background;
            border-radius: 2px;
            border-width: 1px;
            border-color: Palette.border;
            Text {
                text: "Liste des polylignes (" + root.line-count + ")";
                font-size: 11px; font-weight: 700; x: 4px; vertical-alignment: center;
            }
        }
        HorizontalLayout {
            spacing: 2px;
            min-height: 100px;
            vertical-stretch: 1;

            ScrollView {
                horizontal-stretch: 1;
                VerticalLayout {
                    alignment: start;
                    for item[idx] in root.lines-model: Rectangle {
                        height: 20px;
                        background: line-row-ta.has-hover ? Palette.alternate-background
                                  : (line-sel == idx ? #c8deff : Palette.background);
                        border-width: 1px;
                        border-color: line-sel == idx ? #3060cc : Palette.border;
                        line-row-ta := TouchArea {
                            clicked => { line-sel = idx; root.element-selected(1, idx); }
                            double-clicked => { line-sel = idx; root.element-selected(1, idx); root.edit-element(1, idx); }
                        }
                        Text {
                            x: 6px; text: item.text; vertical-alignment: center;
                            font-size: 11px; overflow: elide;
                            color: line-sel == idx ? #0040cc : Palette.foreground;
                        }
                    }
                }
            }
            VerticalLayout {
                width: 65px; spacing: 2px; alignment: start;
                Button { text: "Ajouter"; height: 24px; clicked => { root.add-element(1); } }
                Button { text: "Modifier"; height: 24px; enabled: line-sel >= 0; clicked => { root.edit-element(1, line-sel); } }
                Button { text: "Supprimer"; height: 24px; enabled: line-sel >= 0; clicked => { root.delete-element(1, line-sel); } }
            }
        }

        Rectangle { height: 1px; background: Palette.border; }

        // ── POIs ────────────────────────────────────────
        Rectangle {
            height: 18px;
            background: Palette.control-background;
            border-radius: 2px;
            border-width: 1px;
            border-color: Palette.border;
            Text {
                text: "Liste des POI (" + root.point-count + ")";
                font-size: 11px; font-weight: 700; x: 4px; vertical-alignment: center;
            }
        }
        HorizontalLayout {
            spacing: 2px;
            min-height: 100px;
            vertical-stretch: 1;

            ScrollView {
                horizontal-stretch: 1;
                VerticalLayout {
                    alignment: start;
                    for item[idx] in root.points-model: Rectangle {
                        height: 20px;
                        background: point-row-ta.has-hover ? Palette.alternate-background
                                  : (point-sel == idx ? #c8deff : Palette.background);
                        border-width: 1px;
                        border-color: point-sel == idx ? #3060cc : Palette.border;
                        point-row-ta := TouchArea {
                            clicked => { point-sel = idx; root.element-selected(2, idx); }
                            double-clicked => { point-sel = idx; root.element-selected(2, idx); root.edit-element(2, idx); }
                        }
                        Text {
                            x: 6px; text: item.text; vertical-alignment: center;
                            font-size: 11px; overflow: elide;
                            color: point-sel == idx ? #0040cc : Palette.foreground;
                        }
                    }
                }
            }
            VerticalLayout {
                width: 65px; spacing: 2px; alignment: start;
                Button { text: "Ajouter"; height: 24px; clicked => { root.add-element(2); } }
                Button { text: "Modifier"; height: 24px; enabled: point-sel >= 0; clicked => { root.edit-element(2, point-sel); } }
                Button { text: "Supprimer"; height: 24px; enabled: point-sel >= 0; clicked => { root.delete-element(2, point-sel); } }
            }
        }

        Rectangle { height: 1px; background: Palette.border; }

        // ── POI additionnels ─────────────────────────────
        Rectangle {
            height: 18px;
            background: Palette.control-background;
            border-radius: 2px;
            border-width: 1px;
            border-color: Palette.border;
            Text {
                text: "Liste des POI additionnels";
                font-size: 11px; font-weight: 700; x: 4px; vertical-alignment: center;
            }
        }
        HorizontalLayout {
            spacing: 2px;
            min-height: 80px;
            vertical-stretch: 0.5;

            ScrollView {
                horizontal-stretch: 1;
                VerticalLayout {
                    alignment: start;
                    for item[idx] in root.extra-pois-model: Rectangle {
                        height: 20px;
                        background: icon-row-ta.has-hover ? Palette.alternate-background
                                  : (icon-sel == idx ? #c8deff : Palette.background);
                        border-width: 1px;
                        border-color: icon-sel == idx ? #3060cc : Palette.border;
                        icon-row-ta := TouchArea {
                            clicked => { icon-sel = idx; root.element-selected(3, idx); }
                            double-clicked => { icon-sel = idx; root.element-selected(3, idx); root.edit-element(3, idx); }
                        }
                        Text {
                            x: 6px; text: item.text; vertical-alignment: center;
                            font-size: 11px; overflow: elide;
                            color: icon-sel == idx ? #0040cc : Palette.foreground;
                        }
                    }
                }
            }
            VerticalLayout {
                width: 65px; spacing: 2px; alignment: start;
                Button { text: "Ajouter"; height: 24px; clicked => { root.add-element(3); } }
                Button { text: "Modifier"; height: 24px; enabled: icon-sel >= 0; clicked => { root.edit-element(3, icon-sel); } }
                Button { text: "Supprimer"; height: 24px; enabled: icon-sel >= 0; clicked => { root.delete-element(3, icon-sel); } }
            }
        }

        Rectangle { height: 1px; background: Palette.border; }

        // ── DrawOrder ───────────────────────────────────
        Rectangle {
            height: 18px;
            background: Palette.control-background;
            border-radius: 2px;
            border-width: 1px;
            border-color: Palette.border;
            Text {
                text: "DrawOrder (" + root.draworder-model.length + ")";
                font-size: 11px; font-weight: 700; x: 4px; vertical-alignment: center;
            }
        }
        HorizontalLayout {
            spacing: 2px;
            min-height: 80px;
            vertical-stretch: 0.5;

            StandardListView {
                horizontal-stretch: 1;
                model: root.draworder-model;
            }
            VerticalLayout {
                width: 65px; alignment: start;
                Button { text: "Modifier"; height: 24px; clicked => { root.edit-draworder(); } }
            }
        }

        Rectangle { height: 4px; }
    }
}
