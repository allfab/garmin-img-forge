import { ScrollView, Palette } from "std-widgets.slint";

export struct GalleryItem {
    thumb: image,
    name: string,
    kind: int,
    index: int,
}

export component Gallery inherits Rectangle {
    background: Palette.background;

    in property <[GalleryItem]> items: [];
    in-out property <int> selected-index: -1;

    callback gallery-item-selected(int, int);
    callback gallery-item-edit-requested(int, int);

    VerticalLayout {
        // ── Header : titre ───────────────────────────────
        Rectangle {
            height: 32px;
            background: Palette.control-background;
            border-color: Palette.border;
            border-width: 1px;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 6px;

                Text {
                    text: "Visualisation";
                    vertical-alignment: center;
                    font-size: 12px;
                    font-weight: 600;
                    color: Palette.foreground;
                }
            }
        }

        // ── Grille icônes (5 colonnes) ───────────────────
        icon-scroll := ScrollView {
            vertical-stretch: 1;
            viewport-width: self.visible-width;
            viewport-height: ((root.items.length + 4) / 5) * 96px + 8px;

            Rectangle {
                width: icon-scroll.visible-width;
                height: icon-scroll.viewport-height;

                for item[idx] in root.items : Rectangle {
                    x: mod(idx, 5) * (icon-scroll.visible-width / 5);
                    y: (idx / 5) * 96px + 4px;
                    width: icon-scroll.visible-width / 5 - 1px;
                    height: 92px;

                    border-width: root.selected-index == item.index ? 2px : 1px;
                    border-color: root.selected-index == item.index ? #cc0000 : Palette.border;
                    background: root.selected-index == item.index ? Palette.selection-background
                              : cell-ta.has-hover ? Palette.alternate-background
                              : Palette.background;

                    cell-ta := TouchArea {
                        clicked => {
                            root.selected-index = item.index;
                            root.gallery-item-selected(item.kind, item.index);
                        }
                        double-clicked => {
                            root.selected-index = item.index;
                            root.gallery-item-edit-requested(item.kind, item.index);
                        }
                    }

                    VerticalLayout {
                        alignment: center;
                        spacing: 2px;
                        padding: 6px;

                        Image {
                            source: item.thumb;
                            width: 64px;
                            height: 64px;
                            image-fit: contain;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: item.name;
                            font-size: 9px;
                            horizontal-alignment: center;
                            overflow: elide;
                            wrap: no-wrap;
                        }
                    }
                }
            }
        }
    }
}
