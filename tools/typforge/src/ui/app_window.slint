import { Button, HorizontalBox, CheckBox, TextEdit, SpinBox, LineEdit, ComboBox, ScrollView, StandardListView, Palette } from "std-widgets.slint";
import { LeftPanel } from "left_panel.slint";
import { Gallery, GalleryItem } from "gallery.slint";
import { PreviewPanel } from "preview_panel.slint";
import { PoiEditor, PaletteEntry, LangEntry } from "poi_editor.slint";
import { TxtCodePanel } from "txt_code_panel.slint";
import { PolygonEditor } from "polygon_editor.slint";
import { LineEditor } from "line_editor.slint";

export { GalleryItem, PaletteEntry, LangEntry }

export component AppWindow inherits Window {
    title: "typforge — TYP Editor";
    icon: @image-url("../../favicon.png");
    min-width: 960px;
    min-height: 640px;
    preferred-width: 1280px;
    preferred-height: 800px;
    background: Palette.background;

    // Métadonnées (bi-directionnelles avec panneau gauche)
    in-out property <string> meta-family-id: "";
    in-out property <string> meta-product-code: "";
    in-out property <string> meta-header-str: "";
    in-out property <int>    meta-codepage: 1252;

    // Listes éléments
    in property <[StandardListViewItem]> polygons: [];
    in property <[StandardListViewItem]> lines: [];
    in property <[StandardListViewItem]> points: [];
    in property <[StandardListViewItem]> extra-pois: [];
    in property <[StandardListViewItem]> draworder: [];

    // Galerie
    in property <[GalleryItem]> gallery-items: [];

    // Preview
    in property <image> preview-day;
    in property <image> preview-night;

    // Compteurs barre navigation
    in property <int> poly-count: 0;
    in property <int> line-count: 0;
    in property <int> point-count: 0;
    in property <int> poi-count: 0;

    // Onglet nav actif (0=Poly 1=Line 2=Point 3=Extra)
    in-out property <int> active-nav-tab: 0;

    // Sélection courante (pour re-rendre la preview quand le mode change)
    in-out property <int> selected-kind: -1;
    in-out property <int> selected-idx: -1;

    // Mode preview : 0=Single 1=Mosaic 2=Superposition
    in-out property <int> preview-mode: 0;
    changed preview-mode => { root.preview-mode-changed(root.preview-mode); }

    // Panneau code TXT
    in property <string> selected-txt-code: "";
    in-out property <bool> txt-edit-mode: false;
    in-out property <string> txt-edit-buffer: "";
    in-out property <string> txt-edit-error: "";
    callback txt-edit-apply(string);
    callback txt-edit-cancel();

    // Dialog À propos
    in-out property <bool> about-visible: false;

    // Menu ouvert : 0=aucun 1=Fichier 2=Outils 3=Aide
    private property <int> open-menu: 0;

    // Largeurs des panneaux latéraux (redimensionnables)
    private property <length> left-panel-width: 264px;
    private property <length> right-panel-width: 224px;
    private property <length> txt-panel-height: 220px;

    // Callbacks fichiers
    callback open-file();
    callback save-file();
    callback export-typ();
    callback import-qml();
    callback quit();

    // Callbacks éléments
    callback add-element(int);
    callback edit-element(int, int);
    callback delete-element(int, int);
    callback element-selected(int, int);
    callback edit-draworder();
    callback preview-mode-changed(int);

    // DrawOrder editor
    in-out property <bool>   do-editor-visible: false;
    in-out property <int>    do-selected-idx: -1;
    in-out property <string> do-new-level-text: "0";
    in-out property <string> do-new-type-text: "0x00";
    in-out property <string> do-new-subtype-text: "0x00";
    callback do-add();
    callback do-delete(int);
    callback do-move-up(int);
    callback do-move-down(int);
    callback do-cancel();

    // Callbacks galerie
    callback gallery-item-selected(int, int);

    // Callback navigation
    callback nav-tab-changed(int);

    // ── Éditeur polygone/ligne ───────────────────────────
    in-out property <bool>   editor-visible: false;
    in-out property <int>    editor-kind: 0;
    in-out property <int>    editor-idx: -1;
    in-out property <string> editor-title: "";

    // Champs polygone
    in-out property <string> ep-type-code-text: "0x00";
    in-out property <string> ep-sub-type-text: "0x00";
    in-out property <color>  ep-day-fill-color: #888888;
    in-out property <string> ep-day-fill-text: "#888888";
    in-out property <color>  ep-night-fill-color: #888888;
    in-out property <string> ep-night-fill-text: "#888888";
    in-out property <bool>   ep-extended-labels: false;
    in-out property <int>    ep-font-style: 0;
    in-out property <string> ep-xpm-text: "";
    in-out property <string> ep-night-xpm-text: "";

    // Champs ligne
    in-out property <string> el-type-code-text: "0x00";
    in-out property <string> el-sub-type-text: "0x00";
    in-out property <color>  el-day-color: #000000;
    in-out property <string> el-day-text: "#000000";
    in-out property <color>  el-night-color: #000000;
    in-out property <string> el-night-text: "#000000";
    in-out property <int>    el-line-width: 1;
    in-out property <int>    el-border-width: 0;
    in-out property <bool>   el-use-orientation: true;
    in-out property <bool>   el-extended-labels: false;
    in-out property <int>    el-font-style: 0;
    in-out property <string> el-xpm-text: "";
    in-out property <string> el-night-xpm-text: "";

    callback editor-apply();
    callback editor-cancel();
    in-out property <string> editor-error: "";

    // ── Éditeur POI ──────────────────────────────────────────
    in-out property <bool>   poi-editor-visible: false;
    in-out property <string> poi-type-code-text: "0x00";
    in-out property <string> poi-sub-type-text: "0x00";
    in property <int>        poi-bmp-width: 16;
    in property <int>        poi-bmp-height: 16;
    in property <int>        poi-colour-count: 0;
    in-out property <int>    poi-colormode: 16;
    in property <[PaletteEntry]> poi-palette: [];
    in-out property <int>    poi-active-palette-idx: 0;
    in-out property <string> poi-new-color-hex: "#000000";
    in property <image>      poi-grid-image;
    in-out property <int>    poi-zoom: 12;
    in-out property <int>    poi-active-tool: 0;
    in-out property <int>    poi-brush-size: 1;
    in property <image>      poi-preview-day;
    in property <image>      poi-preview-night;
    in-out property <bool>   poi-has-night-bmp: false;
    in-out property <bool>   poi-editing-night: false;
    in-out property <bool>   poi-extended-labels: false;
    in-out property <int>    poi-font-style-idx: 0;
    in-out property <string> poi-font-color-day-text: "#000000";
    in-out property <string> poi-font-color-night-text: "#000000";
    in property <[LangEntry]> poi-lang-labels: [];
    in-out property <int>    poi-selected-lang: -1;
    in-out property <string> poi-selected-lang-name: "";
    in-out property <string> poi-selected-lang-text: "";
    in-out property <string> poi-resize-width-text: "16";
    in-out property <string> poi-resize-height-text: "16";

    callback poi-grid-clicked(float, float, int);
    callback poi-palette-selected(int);
    callback poi-palette-add();
    callback poi-palette-remove();
    callback poi-resize-bmp(int, int);
    callback poi-import-image();
    callback poi-trim-colours();
    callback poi-garmin-colours();
    callback poi-copy-day-to-night();
    callback poi-toggle-night-edit();
    callback poi-lang-selected(int);
    callback poi-lang-text-changed(string);
    callback poi-set-as-default();
    callback poi-editor-apply();
    callback poi-editor-cancel();
    in-out property <string> poi-editor-error: "";
    callback poi-zoom-changed(int);
    callback poi-tool-changed(int);

    // Color picker callbacks
    callback pick-ep-day-color();
    callback pick-ep-night-color();
    callback pick-el-day-color();
    callback pick-el-night-color();
    callback pick-poi-new-color();
    callback pick-poi-font-day-color();
    callback pick-poi-font-night-color();

    // Callbacks live hex → couleur pour preview instantanée dans les éditeurs
    callback ep-day-text-changed(string);
    callback ep-night-text-changed(string);
    callback el-day-text-changed(string);
    callback el-night-text-changed(string);
    in-out property <color> poi-font-color-day: #000000;
    in-out property <color> poi-font-color-night: #000000;
    in-out property <color> poi-new-color-preview: #000000;

    VerticalLayout {
        // ── Barre de menu ────────────────────────────────
        Rectangle {
            height: 22px;
            background: Palette.control-background;

            HorizontalLayout {
                alignment: start;
                padding: 0px;

                Rectangle {
                    width: 60px; height: 22px;
                    background: (root.open-menu == 1 || fichier-ta.has-hover) ? Palette.selection-background : transparent;
                    Text { text: "Fichier"; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                    fichier-ta := TouchArea {
                        clicked => { root.open-menu = root.open-menu == 1 ? 0 : 1; }
                    }
                }
                Rectangle {
                    width: 60px; height: 22px;
                    background: (root.open-menu == 2 || outils-ta.has-hover) ? Palette.selection-background : transparent;
                    Text { text: "Outils"; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                    outils-ta := TouchArea {
                        clicked => { root.open-menu = root.open-menu == 2 ? 0 : 2; }
                    }
                }
                Rectangle {
                    width: 60px; height: 22px;
                    background: (root.open-menu == 3 || aide-ta.has-hover) ? Palette.selection-background : transparent;
                    Text { text: "Aide"; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                    aide-ta := TouchArea {
                        clicked => { root.open-menu = root.open-menu == 3 ? 0 : 3; }
                    }
                }
            }
        }

        Rectangle { height: 1px; background: Palette.border; }

        // ── Barre d'outils ──────────────────────────────
        Rectangle {
            height: 38px;
            background: Palette.control-background;
            border-color: Palette.border;
            border-width: 0px;

            HorizontalLayout {
                padding: 4px;
                spacing: 4px;
                alignment: start;

                Button {
                    text: "Ouvrir";
                    height: 28px;
                    clicked => { root.open-file(); }
                }
                Button {
                    text: "Enregistrer";
                    height: 28px;
                    clicked => { root.save-file(); }
                }
                Button {
                    text: "Enregistrer .TYP";
                    height: 28px;
                    clicked => { root.export-typ(); }
                }
                Button {
                    text: "Importer QML";
                    height: 28px;
                    clicked => { root.import-qml(); }
                }
                Rectangle { horizontal-stretch: 1; }
                Button {
                    text: "Quitter";
                    height: 28px;
                    clicked => { root.quit(); }
                }
            }
        }

        // ── Métadonnées (bande pleine largeur) ──────────
        Rectangle {
            height: 30px;
            background: Palette.alternate-background;

            HorizontalLayout {
                padding: 4px; spacing: 8px; alignment: start;
                Text { text: "FID:"; font-size: 11px; width: 28px; vertical-alignment: center; }
                LineEdit { text <=> root.meta-family-id; width: 60px; }
                Rectangle { width: 1px; background: Palette.border; }
                Text { text: "Produit:"; font-size: 11px; width: 50px; vertical-alignment: center; }
                LineEdit { text <=> root.meta-product-code; width: 50px; }
                Rectangle { width: 1px; background: Palette.border; }
                Text { text: "CodePage:"; font-size: 11px; width: 62px; vertical-alignment: center; }
                ComboBox {
                    model: ["1252 (CP1252)", "65001 (UTF-8)"];
                    current-index: root.meta-codepage == 65001 ? 1 : 0;
                    selected(v) => { root.meta-codepage = v == "65001 (UTF-8)" ? 65001 : 1252; }
                    width: 130px;
                }
                Rectangle { width: 1px; background: Palette.border; }
                Text { text: "En-tête:"; font-size: 11px; width: 50px; vertical-alignment: center; }
                LineEdit { text <=> root.meta-header-str; horizontal-stretch: 1; }
            }
        }

        Rectangle { height: 1px; background: Palette.border; }

        // ── Barre navigation ────────────────────────────
        Rectangle {
            height: 38px;
            background: Palette.alternate-background;

            HorizontalLayout {
                padding: 4px;
                spacing: 4px;
                alignment: start;

                Rectangle {
                    width: 120px; height: 28px;
                    border-radius: 4px;
                    background: root.active-nav-tab == 0 ? #3080ff : Palette.control-background;
                    Text {
                        text: "Polygones [" + root.poly-count + "]";
                        color: root.active-nav-tab == 0 ? #ffffff : Palette.foreground;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    TouchArea {
                        clicked => {
                            root.active-nav-tab = 0;
                            root.nav-tab-changed(0);
                        }
                    }
                }
                Rectangle {
                    width: 120px; height: 28px;
                    border-radius: 4px;
                    background: root.active-nav-tab == 1 ? #3080ff : Palette.control-background;
                    Text {
                        text: "Lignes [" + root.line-count + "]";
                        color: root.active-nav-tab == 1 ? #ffffff : Palette.foreground;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    TouchArea {
                        clicked => {
                            root.active-nav-tab = 1;
                            root.nav-tab-changed(1);
                        }
                    }
                }
                Rectangle {
                    width: 120px; height: 28px;
                    border-radius: 4px;
                    background: root.active-nav-tab == 2 ? #3080ff : Palette.control-background;
                    Text {
                        text: "POIs [" + root.point-count + "]";
                        color: root.active-nav-tab == 2 ? #ffffff : Palette.foreground;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    TouchArea {
                        clicked => {
                            root.active-nav-tab = 2;
                            root.nav-tab-changed(2);
                        }
                    }
                }
                Rectangle {
                    width: 120px; height: 28px;
                    border-radius: 4px;
                    background: root.active-nav-tab == 3 ? #3080ff : Palette.control-background;
                    Text {
                        text: "Pois+ [" + root.poi-count + "]";
                        color: root.active-nav-tab == 3 ? #ffffff : Palette.foreground;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    TouchArea {
                        clicked => {
                            root.active-nav-tab = 3;
                            root.nav-tab-changed(3);
                        }
                    }
                }
            }
        }

        // ── 3 panneaux ──────────────────────────────────
        HorizontalLayout {
            vertical-stretch: 1;

            // Panneau gauche
            left := LeftPanel {
                width: root.left-panel-width;
                polygons-model: root.polygons;
                lines-model: root.lines;
                points-model: root.points;
                extra-pois-model: root.extra-pois;
                draworder-model: root.draworder;
                poly-count: root.poly-count;
                line-count: root.line-count;
                point-count: root.point-count;
                poi-count: root.poi-count;
                active-kind: root.active-nav-tab;
                add-element(kind) => { root.add-element(kind); }
                edit-element(kind, idx) => { root.edit-element(kind, idx); }
                delete-element(kind, idx) => { root.delete-element(kind, idx); }
                element-selected(kind, idx) => { root.element-selected(kind, idx); }
                edit-draworder => { root.edit-draworder(); }
                nav-requested(kind) => {
                    root.active-nav-tab = kind;
                    root.nav-tab-changed(kind);
                }
            }

            // Séparateur gauche (draggable)
            Rectangle {
                width: 5px;
                background: left-spl-ta.has-hover || left-spl-ta.pressed ? #5090ff : #aaaaaa;
                left-spl-ta := TouchArea {
                    mouse-cursor: col-resize;
                    moved => {
                        root.left-panel-width = clamp(
                            root.left-panel-width + self.mouse-x - 2.5px,
                            120px, 500px
                        );
                    }
                }
            }

            // Panneau central : galerie + code TXT (sous la galerie)
            VerticalLayout {
                horizontal-stretch: 1;

                gallery := Gallery {
                    vertical-stretch: 1;
                    items: root.gallery-items;
                    selected-index <=> root.selected-idx;
                    gallery-item-selected(kind, idx) => { root.gallery-item-selected(kind, idx); }
                    gallery-item-edit-requested(kind, idx) => { root.edit-element(kind, idx); }
                }

                if root.selected-kind >= 0 : Rectangle {
                    height: 5px;
                    background: txt-spl-ta.has-hover || txt-spl-ta.pressed ? #5090ff : #aaaaaa;
                    txt-spl-ta := TouchArea {
                        mouse-cursor: row-resize;
                        moved => {
                            root.txt-panel-height = clamp(
                                root.txt-panel-height + 2.5px - self.mouse-y,
                                80px, 500px
                            );
                        }
                    }
                }

                if root.selected-kind >= 0 : TxtCodePanel {
                    height: root.txt-panel-height;
                    txt-code: root.selected-txt-code;
                    edit-mode <=> root.txt-edit-mode;
                    edit-buffer <=> root.txt-edit-buffer;
                    error-msg: root.txt-edit-error;
                    edit-apply(s) => { root.txt-edit-apply(s); }
                    edit-cancel => { root.txt-edit-cancel(); }
                }
            }

            // Séparateur droit (draggable)
            Rectangle {
                width: 5px;
                background: right-spl-ta.has-hover || right-spl-ta.pressed ? #5090ff : #aaaaaa;
                right-spl-ta := TouchArea {
                    mouse-cursor: col-resize;
                    moved => {
                        root.right-panel-width = clamp(
                            root.right-panel-width + 2.5px - self.mouse-x,
                            120px, 500px
                        );
                    }
                }
            }

            // Panneau droit : preview uniquement
            PreviewPanel {
                width: root.right-panel-width;
                preview-day: root.preview-day;
                preview-night: root.preview-night;
                preview-mode <=> root.preview-mode;
            }
        }
    }

    // ── Overlay éditeur POI ──────────────────────────────
    if root.poi-editor-visible : PoiEditor {
        x: 0; y: 0;
        width: root.width; height: root.height;
        type-code-text <=> root.poi-type-code-text;
        sub-type-text <=> root.poi-sub-type-text;
        bmp-width: root.poi-bmp-width;
        bmp-height: root.poi-bmp-height;
        colour-count: root.poi-colour-count;
        colormode <=> root.poi-colormode;
        palette: root.poi-palette;
        active-palette-idx <=> root.poi-active-palette-idx;
        new-color-hex <=> root.poi-new-color-hex;
        grid-image: root.poi-grid-image;
        zoom <=> root.poi-zoom;
        active-tool <=> root.poi-active-tool;
        brush-size <=> root.poi-brush-size;
        preview-day: root.poi-preview-day;
        preview-night: root.poi-preview-night;
        has-night-bmp <=> root.poi-has-night-bmp;
        editing-night <=> root.poi-editing-night;
        extended-labels <=> root.poi-extended-labels;
        font-style-idx <=> root.poi-font-style-idx;
        font-color-day-text <=> root.poi-font-color-day-text;
        font-color-night-text <=> root.poi-font-color-night-text;
        font-color-day <=> root.poi-font-color-day;
        font-color-night <=> root.poi-font-color-night;
        new-color-preview <=> root.poi-new-color-preview;
        lang-labels: root.poi-lang-labels;
        selected-lang <=> root.poi-selected-lang;
        selected-lang-name <=> root.poi-selected-lang-name;
        selected-lang-text <=> root.poi-selected-lang-text;
        resize-width-text <=> root.poi-resize-width-text;
        resize-height-text <=> root.poi-resize-height-text;
        grid-clicked(fx, fy, btn) => { root.poi-grid-clicked(fx, fy, btn); }
        palette-selected(i) => { root.poi-palette-selected(i); }
        palette-add => { root.poi-palette-add(); }
        palette-remove => { root.poi-palette-remove(); }
        resize-bmp(w, h) => { root.poi-resize-bmp(w, h); }
        import-image => { root.poi-import-image(); }
        trim-colours => { root.poi-trim-colours(); }
        garmin-colours => { root.poi-garmin-colours(); }
        copy-day-to-night => { root.poi-copy-day-to-night(); }
        toggle-night-edit => { root.poi-toggle-night-edit(); }
        lang-selected(c) => { root.poi-lang-selected(c); }
        lang-text-changed(t) => { root.poi-lang-text-changed(t); }
        set-as-default => { root.poi-set-as-default(); }
        editor-error <=> root.poi-editor-error;
        editor-apply => { root.poi-editor-apply(); }
        editor-cancel => { root.poi-editor-cancel(); }
        zoom-changed(v) => { root.poi-zoom-changed(v); }
        tool-changed(t) => { root.poi-tool-changed(t); }
        pick-new-color => { root.pick-poi-new-color(); }
        pick-font-day-color => { root.pick-poi-font-day-color(); }
        pick-font-night-color => { root.pick-poi-font-night-color(); }
    }

    // ── Overlay éditeur polygone ─────────────────────────────────
    if root.editor-visible && root.editor-kind == 0 : PolygonEditor {
        x: 0; y: 0; width: root.width; height: root.height;
        title-text: root.editor-title;
        type-code-text <=> root.ep-type-code-text;
        sub-type-text  <=> root.ep-sub-type-text;
        day-fill-color   <=> root.ep-day-fill-color;
        day-fill-text    <=> root.ep-day-fill-text;
        night-fill-color <=> root.ep-night-fill-color;
        night-fill-text  <=> root.ep-night-fill-text;
        extended-labels <=> root.ep-extended-labels;
        font-style      <=> root.ep-font-style;
        xpm-text        <=> root.ep-xpm-text;
        night-xpm-text  <=> root.ep-night-xpm-text;
        error-msg       <=> root.editor-error;
        day-text-changed(v)   => { root.ep-day-text-changed(v); }
        night-text-changed(v) => { root.ep-night-text-changed(v); }
        pick-day-color   => { root.pick-ep-day-color(); }
        pick-night-color => { root.pick-ep-night-color(); }
        apply  => { root.editor-apply(); }
        cancel => { root.editor-cancel(); }
    }

    // ── Overlay éditeur ligne ────────────────────────────────────
    if root.editor-visible && root.editor-kind == 1 : LineEditor {
        x: 0; y: 0; width: root.width; height: root.height;
        title-text: root.editor-title;
        type-code-text <=> root.el-type-code-text;
        sub-type-text  <=> root.el-sub-type-text;
        day-color  <=> root.el-day-color;
        day-text   <=> root.el-day-text;
        night-color <=> root.el-night-color;
        night-text  <=> root.el-night-text;
        line-width   <=> root.el-line-width;
        bdr-width <=> root.el-border-width;
        use-orientation <=> root.el-use-orientation;
        extended-labels <=> root.el-extended-labels;
        font-style      <=> root.el-font-style;
        xpm-text        <=> root.el-xpm-text;
        night-xpm-text  <=> root.el-night-xpm-text;
        error-msg       <=> root.editor-error;
        day-text-changed(v)   => { root.el-day-text-changed(v); }
        night-text-changed(v) => { root.el-night-text-changed(v); }
        pick-day-color   => { root.pick-el-day-color(); }
        pick-night-color => { root.pick-el-night-color(); }
        apply  => { root.editor-apply(); }
        cancel => { root.editor-cancel(); }
    }

    // ── Overlay À propos ─────────────────────────────────────────
    if root.about-visible : Rectangle {
        x: 0; y: 0; width: root.width; height: root.height;
        background: #00000055;

        Rectangle {
            x: (parent.width - 360px) / 2;
            y: (parent.height - 200px) / 2;
            width: 360px; height: 200px;
            background: Palette.background;
            border-width: 1px; border-color: #888888;

            VerticalLayout {
                padding: 0px;
                Rectangle {
                    height: 36px; background: #2060b0;
                    Text {
                        text: "À propos de TypForge";
                        color: #ffffff; font-size: 13px; font-weight: 700;
                        horizontal-alignment: center; vertical-alignment: center;
                    }
                }
                VerticalLayout {
                    vertical-stretch: 1; padding: 16px; spacing: 6px; alignment: center;
                    Text {
                        text: "TypForge — Éditeur de fichiers TYP Garmin";
                        font-size: 12px; horizontal-alignment: center;
                    }
                    Text {
                        text: "Version 0.1.0";
                        font-size: 11px; color: Palette.foreground;
                        horizontal-alignment: center;
                    }
                }
                Rectangle {
                    height: 46px; background: Palette.control-background;
                    border-width: 1px; border-color: Palette.border;
                    HorizontalLayout { padding: 8px; alignment: end;
                        Button { text: "OK"; height: 30px; clicked => { root.about-visible = false; } }
                    }
                }
            }
        }
    }

    // ── Overlay éditeur DrawOrder ────────────────────────────────
    if root.do-editor-visible : Rectangle {
        x: 0; y: 0; width: root.width; height: root.height;
        background: #00000055;

        Rectangle {
            x: (parent.width - 500px) / 2;
            y: (parent.height - 380px) / 2;
            width: 500px; height: 380px;
            background: Palette.background;
            border-width: 1px; border-color: #888888;

            VerticalLayout { padding: 0px;
                // Titre
                Rectangle {
                    height: 36px; background: #2060b0;
                    Text { text: "DrawOrder"; color: #ffffff; font-size: 13px; font-weight: 700;
                        horizontal-alignment: center; vertical-alignment: center; }
                }

                // Corps
                HorizontalLayout { vertical-stretch: 1; padding: 8px; spacing: 10px;
                    // Gauche : liste + boutons Monter/Descendre/Supprimer
                    VerticalLayout { horizontal-stretch: 1; spacing: 4px;
                        do-list := StandardListView {
                            vertical-stretch: 1;
                            model: root.draworder;
                            current-item <=> root.do-selected-idx;
                        }
                        HorizontalLayout { spacing: 4px;
                            Button { text: "↑"; height: 26px; clicked => { root.do-move-up(root.do-selected-idx); } }
                            Button { text: "↓"; height: 26px; clicked => { root.do-move-down(root.do-selected-idx); } }
                            Rectangle { horizontal-stretch: 1; }
                            Button { text: "Supprimer"; height: 26px; clicked => { root.do-delete(root.do-selected-idx); } }
                        }
                    }

                    // Droite : formulaire ajout nouvelle entrée
                    VerticalLayout { width: 190px; spacing: 6px; alignment: start;
                        Text { text: "Nouvelle entrée"; font-size: 11px; font-weight: 700; color: Palette.foreground; }
                        HorizontalLayout { spacing: 4px;
                            Text { text: "Level:"; font-size: 11px; width: 60px; vertical-alignment: center; }
                            LineEdit { text <=> root.do-new-level-text; }
                        }
                        HorizontalLayout { spacing: 4px;
                            Text { text: "Type (hex):"; font-size: 11px; width: 60px; vertical-alignment: center; }
                            LineEdit { text <=> root.do-new-type-text; }
                        }
                        HorizontalLayout { spacing: 4px;
                            Text { text: "SubType:"; font-size: 11px; width: 60px; vertical-alignment: center; }
                            LineEdit { text <=> root.do-new-subtype-text; }
                        }
                        Button { text: "Ajouter"; height: 26px; clicked => { root.do-add(); } }
                    }
                }

                // Pied de fenêtre
                Rectangle {
                    height: 46px; background: Palette.control-background;
                    border-width: 1px; border-color: Palette.border;
                    HorizontalLayout { padding: 8px; spacing: 8px; alignment: end;
                        Button { text: "Fermer"; height: 30px; clicked => { root.do-cancel(); } }
                    }
                }
            }
        }
    }

    // ── Fermeture menu sur clic en dehors ────────────────
    if root.open-menu != 0 : TouchArea {
        x: 0; y: 0; width: root.width; height: root.height;
        clicked => { root.open-menu = 0; }
    }

    // ── Dropdown Fichier ─────────────────────────────────
    if root.open-menu == 1 : Rectangle {
        x: 0px; y: 23px;
        width: 210px; height: 126px;
        background: Palette.background;
        border-width: 1px; border-color: #888888;

        VerticalLayout {
            padding: 0px; spacing: 0px;
            Rectangle {
                height: 24px;
                background: mi-ouvrir-ta.has-hover ? Palette.selection-background : transparent;
                HorizontalLayout { padding-left: 10px; alignment: start;
                    Text { text: "Ouvrir…"; font-size: 11px; vertical-alignment: center; }
                }
                mi-ouvrir-ta := TouchArea { clicked => { root.open-file(); root.open-menu = 0; } }
            }
            Rectangle {
                height: 24px;
                background: mi-save-ta.has-hover ? Palette.selection-background : transparent;
                HorizontalLayout { padding-left: 10px; alignment: start;
                    Text { text: "Enregistrer"; font-size: 11px; vertical-alignment: center; }
                }
                mi-save-ta := TouchArea { clicked => { root.save-file(); root.open-menu = 0; } }
            }
            Rectangle {
                height: 24px;
                background: mi-typ-ta.has-hover ? Palette.selection-background : transparent;
                HorizontalLayout { padding-left: 10px; alignment: start;
                    Text { text: "Enregistrer .TYP"; font-size: 11px; vertical-alignment: center; }
                }
                mi-typ-ta := TouchArea { clicked => { root.export-typ(); root.open-menu = 0; } }
            }
            Rectangle { height: 1px; background: Palette.border; }
            Rectangle {
                height: 24px;
                background: mi-quit-ta.has-hover ? Palette.selection-background : transparent;
                HorizontalLayout { padding-left: 10px; alignment: start;
                    Text { text: "Quitter"; font-size: 11px; vertical-alignment: center; }
                }
                mi-quit-ta := TouchArea { clicked => { root.quit(); } }
            }
        }
    }

    // ── Dropdown Outils ──────────────────────────────────
    if root.open-menu == 2 : Rectangle {
        x: 60px; y: 23px;
        width: 180px; height: 26px;
        background: Palette.background;
        border-width: 1px; border-color: #888888;

        VerticalLayout {
            padding: 0px;
            Rectangle {
                height: 24px;
                background: mi-qml-ta.has-hover ? Palette.selection-background : transparent;
                HorizontalLayout { padding-left: 10px; alignment: start;
                    Text { text: "Importer QML"; font-size: 11px; vertical-alignment: center; }
                }
                mi-qml-ta := TouchArea { clicked => { root.import-qml(); root.open-menu = 0; } }
            }
        }
    }

    // ── Dropdown Aide ────────────────────────────────────
    if root.open-menu == 3 : Rectangle {
        x: 120px; y: 23px;
        width: 200px; height: 26px;
        background: Palette.background;
        border-width: 1px; border-color: #888888;

        VerticalLayout {
            padding: 0px;
            Rectangle {
                height: 24px;
                background: mi-about-ta.has-hover ? Palette.selection-background : transparent;
                HorizontalLayout { padding-left: 10px; alignment: start;
                    Text { text: "À propos de TypForge"; font-size: 11px; vertical-alignment: center; }
                }
                mi-about-ta := TouchArea { clicked => { root.about-visible = true; root.open-menu = 0; } }
            }
        }
    }
}
